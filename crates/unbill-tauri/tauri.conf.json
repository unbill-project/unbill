{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unbill",
  "version": "0.1.0",
  "identifier": "com.unbill.app",
  "build": {
    "beforeDevCommand": "pnpm --filter unbill-desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter unbill-desktop build",
    "frontendDist": "../../apps/unbill-desktop/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "unbill",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
