{
  "name": "unbill",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "trunk serve --config apps/unbill-ui-leptos/Trunk.toml",
    "dev:leptos": "trunk serve --config apps/unbill-ui-leptos/Trunk.toml",
    "build": "trunk build --config apps/unbill-ui-leptos/Trunk.toml --release",
    "build:leptos": "trunk build --config apps/unbill-ui-leptos/Trunk.toml --release",
    "lint": "cargo clippy --workspace --all-targets",
    "typecheck": "cargo check --workspace",
    "tauri:dev": "cd crates/unbill-tauri && cargo tauri dev",
    "tauri:dev:leptos": "cd crates/unbill-tauri && cargo tauri dev",
    "tauri:build": "cd crates/unbill-tauri && cargo tauri build",
    "tauri:build:leptos": "cd crates/unbill-tauri && cargo tauri build"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
